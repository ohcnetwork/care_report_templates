{% set report_title ="Discharge Bill"%}
{% set logo_img ="input_logo_image_url" %}
<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <style>
        @page {
            size: A4;
            margin: 140px 40px 80px 40px;
        }


        body {
            line-spacing: 1.6;
            font-family: "Times New Roman", Times, serif;
            margin: 0;
            padding: 0;
            max-width: 100%;
            font-size: 12px;
        }

        h1,
        h2,
        h3 {
            color: #2E8B57;
        }

        h1 {
            text-align: center;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        h2 {
            border-bottom: 1px solid #333;
        }

        table {
            width: 100%;
            margin: 10px 0 20px 0;
            border: none;
            line-height: 1.2;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 4px 8px;
            text-align: left;
            font-size: 10px;
        }

        .sub-table th {
            background-color: #FAFAFA;
            font-size: 10px;
        }

        .sub-table th,
        .sub-table td {

            margin-top: 30px;
        }

        .sub-table {
            white-space: pre-line;
            overflow-wrap: break-word;
        }

        .no-border,
        .no-border th,
        .no-border td {
            border: none !important;
            padding: 3px;
        }

        .no-border th {
            background-color: transparent !important;
        }

        .note-text {
            font-style: italic;
            font-size: 8px;
            margin-top: 12px;
        }


        .footer {
            margin-top: 8px;
            padding-top: 0;
            border-top: 1px solid #333;
            font-size: 8px;
            color: #666;
            text-align: center;
        }

        .separator {
            border-top: 1px solid #333;
            margin: 10px 0;
        }

        .header {
            position: fixed;
            top: -150px;
            left: 0;
            right: 0;

            height: 120px;
            padding: 10px;

            display: flex;
            justify-content: space-between;
            align-items: center;

            background: white;


            z-index: 2;
        }


        .header-logo {
            height: 50px;
            width: auto;
        }

        .header-title {
            flex-grow: 1;
            text-align: center;
        }

        .header-title h1 {
            margin: 0;
            border: none;
            padding: 0;
            font-size: 24px;
            color: #2E8B57;
        }

        .header-placeholder {
            width: 100%;
        }

        .invoice-table {
            width: 100%;
        }

        .invoice-row {
            display: flex;
            padding: 1px 0;
            font-size: 10px;
        }

        .account-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            column-gap: 10px;
            align-items: center;
        }

        .invoice-header {
            font-weight: bold;
            border-bottom: 1px solid #ddd;
            border-top: 1px solid #ddd
        }

        .category-row {
            font-weight: 600;
            border-bottom: 1px solid #f5f5f5;
            border-top: 1px solid #f5f5f5
        }

        .col-date {
            width: 15%;
        }

        .col-title {
            width: 35%;
        }

        .col-status {
            width: 15%;
        }

        .col-rate {
            width: 15%;
            display: flex;
            justify-content: left;
        }

        .col-qty {
            width: 10%;
            display: flex;
            justify-content: center;
        }

        .col-amount {
            width: 15%;
            display: flex;
            justify-content: right;
        }

        .col-account-amount {
            text-align: center;
        }

        .col-invoice {
            width: 20%;
            display: flex;
            justify-content: left;
        }

        .col-method {
            width: 25%;
            display: flex;
            justify-content: left;
        }

        .col-full {
            width: 100%;
            display: flex;
            justify-content: space-between;
        }

        .net-total {
            display: flex;
            justify-content: right;
            font-weight: bold;
            font-size: 10px;
        }

        .billed-row {
            /* background-color: #ffe5e5; */
            color: #a10000;
        }

        .payment-header {
            display: flex;
            justify-content: space-between;
        }

        .payment-group {
            display: flex;
            width: 70%;
            justify-content: space-between
        }

        .summary-box {
            page-break-inside: avoid;
        }

        /* .bar-code {
            position: absolute;
            right: 0px;

        } */


        .content {
            position: relative;
            z-index: 5;
            margin-top: -40px;

            @media print {
                .header {
                    display: flex !important;
                }
            }
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="header-title">
            <h1 style="text-align: left;">{{ account.facility.name }}</h1>
            <div style="text-align: left; font-size:10px;">{{ account.facility.address }}<p>{{
                    account.facility.phone_number }}</p>
            </div>
        </div>
        <img alt="Logo" src={{logo_img}} style="height: 100px; width: auto;">
    </div>
    <div class="content">
        <h2 style="text-align: center;">{{report_title}}</h2>
        <table class="no-border">
            <tr>
                <th>Name</th>
                <td>{{ account.patient.name }}</td>

                <th>Date</th>
                <td> {{current_date()}}</>
            </tr>

            {% set official_identifiers = account.patient.instance_identifiers|selectattr('config.use', 'equalto',
            'Official')|list %}

            <tr>
                <th>Age</th>
                <td>{{ account.patient.age }}</td>

                {% if official_identifiers|length > 0 %}
                <th>{{ official_identifiers[0].config.display }}</th>
                <td>{{ official_identifiers[0].value }}</td>
                {% endif %}
            </tr>

            <tr>
                <th>Gender</th>
                <td>{{ account.patient.gender }}</td>
                <th>Admission Date/Time</th>
                <td> {% if account.primary_encounter %}{{account.primary_encounter.start_time |datetime}}{% endif %}</>

            </tr>

            <tr>
                <th>Address</th>
                <td>{{account.patient.address }}</td>
                <th>Discharge Date/Time</th>
                <td> {% if account.primary_encounter %}{{account.primary_encounter.end_time |datetime}}{% endif %}</>
            </tr>
            <tr>
                <th>Bed</th>
                <td>{% if account.primary_encounter %}{{ account.primary_encounter.current_location.name }}{% endif %}
                </td>
            </tr>

        </table>

        <div class="invoice-table">

            <!-- Header -->
            <div class="invoice-row invoice-header">
                <div class="col-date">Date</div>
                <div class="col-invoice">Invoice</div>
                <div class="col-title">Title</div>
                <div class="col-status">Status</div>
                <div class="col-rate">Rate</div>
                <div class="col-qty">Qty</div>
                <div class="col-amount">Amount</div>
            </div>
            {% set ns = namespace(net_total=0) %}
            {% for category_charge_item in account.category_charge_items_summary.category_charge_items %}

            <!-- Category Title Row -->
            <div class="invoice-row category-row">
                <div class="col-full">
                    <div>{{ category_charge_item.category.title }}</div>
                    <div>₹{{category_charge_item.total_charge_items_price | float}}</div>
                </div>
            </div>

            {% for charge_item in category_charge_item.charge_items %}

            <div class="invoice-row  {% if charge_item.status in ['Billed', 'Billable'] %}
        billed-row
    {% endif %} ">
                <div class="col-date">
                    {{ charge_item.created_date | date }}
                </div>
                <div class="col-invoice">
                    {{ charge_item.paid_invoice.number }}
                </div>
                <div class="col-title">
                    {{ charge_item.title }}
                </div>
                <div class="col-status">
                    {{ charge_item.status }}
                </div>

                <div class="col-rate">
                    {% for unit_price_component in charge_item.unit_price_components %}
                    {% if unit_price_component.monetary_component_type == "Base" %}
                    ₹{{ unit_price_component.amount }}
                    {% endif %}
                    {% endfor %}
                </div>


                <div class="col-qty">
                    {{ charge_item.quantity | int }}
                </div>

                <div class="col-amount">
                    ₹{{ charge_item.total_price |float }}
                </div>
            </div>

            {% endfor %}
            {% set ns.net_total = ns.net_total + (category_charge_item.total_charge_items_price | float) %}
            {% endfor %}

        </div>
        <div class="net-total">
            Net Total ₹{{ ns.net_total | float }}
        </div>

        <div style="font-weight: bold; font-size: 14px; margin-bottom: 10px;">
            Returned
        </div>
        <div class="invoice-table">

            <!-- Header -->
            <div class="invoice-row invoice-header">
                <div class="col-date">Date</div>
                <div class="col-invoice">Invoice</div>
                <div class="col-title">Title</div>
                <div class="col-status">Status</div>
                <div class="col-rate">Rate</div>
                <div class="col-qty">Qty</div>
                <div class="col-amount">Amount</div>
            </div>
            {% set ns = namespace(net_returned_total=0) %}
            {% for category_charge_item in account.category_charge_items_summary.category_returned_charge_items %}

            <!-- Category Title Row -->
            <div class="invoice-row category-row">
                <div class="col-full">
                    <div style="width:650px">{{ category_charge_item.category.title }}</div>
                    <div>₹{{category_charge_item.total_charge_items_price | float}}</div>
                </div>
            </div>

            {% for charge_item in category_charge_item.charge_items %}

            <div class="invoice-row 
                {% if charge_item.status in ['billed', 'billable'] %}
                        billed-row
                {% endif %}">
                <div class="col-date">
                    {{ charge_item.created_date | date }}
                </div>
                <div class="col-invoice">
                    {{ charge_item.paid_invoice.number }}
                </div>
                <div class="col-title">
                    {{ charge_item.title }}
                </div>
                <div class="col-status">
                    {{ charge_item.status }}
                </div>

                <div class="col-rate">
                    {% for unit_price_component in charge_item.unit_price_components %}
                    {% if unit_price_component.monetary_component_type == "Base" %}
                    ₹{{ unit_price_component.amount }}
                    {% endif %}
                    {% endfor %}
                </div>


                <div class="col-qty">
                    {{ charge_item.quantity | int }}
                </div>

                <div class="col-amount">
                    ₹{{ charge_item.total_price |float }}
                </div>
            </div>

            {% endfor %}
            {% set ns.net_returned_total = ns.net_returned_total + (category_charge_item.total_charge_items_price |
            float) %}
            {% endfor %}

            <div class="net-total">
                Net Total ₹{{ ns.net_returned_total | float }}
            </div>
        </div>

        <div class="separator"></div>
        <div style="font-weight: bold; font-size: 14px; margin-bottom: 10px;">
            Payment Details
        </div>
        <div class="invoice-table">

            <!-- Header -->
            <div class="invoice-row invoice-header payment-header">
                <div class="payment-group">
                    <div class="col-date">Date</div>
                    <div class="col-invoice">Invoice</div>
                    <div class="col-method">Method</div>
                </div>
                <div class="col-amount">Amount</div>
            </div>

            {% set ns = namespace(net_payment_total=0) %}

            {% for group in account.payment_reconciliations | groupby("reconciliation_type") %}

            <!-- Group Heading -->
            <div style="font-weight:bold; margin-top:10px; font-size:10px">
                {{ group.grouper }}
            </div>

            {% for payment_reconciliation in group.list %}

            <div class="invoice-row" style="justify-content:space-between">

                <div class="payment-group">

                    <div class="col-date">
                        {{ payment_reconciliation.created_date | date }}
                    </div>

                    <div class="col-invoice">
                        {{ payment_reconciliation.target_invoice.number }}
                    </div>

                    <div class="col-method">
                        {{ payment_reconciliation.method }}
                    </div>

                </div>

                <div class="col-amount">
                    ₹{{ payment_reconciliation.amount | float }}
                </div>

            </div>

            {% set ns.net_payment_total = ns.net_payment_total + (payment_reconciliation.amount | float) %}

            {% endfor %}

            {% endfor %}

            <div class="net-total">
                Net Total ₹{{ ns.net_payment_total | float }}
            </div>
        </div>


        <div class="summary-box">
            <div style="font-weight: bold; font-size: 14px; margin-bottom: 10px;">
                Summary
            </div>

            <div class="invoice-row invoice-header account-row">
                <div>Billed (Gross)</div>
                <div class="col-account-amount">Total Paid</div>
                <div class="col-account-amount">Amount Due</div>
                <div style="text-align: right">Total Billable</div>
            </div>

            <div class="account-row invoice-row">
                <div>₹{{ account.total_gross |float }}</div>
                <div class="col-account-amount">₹{{ account.total_paid |float }}</div>
                <div class="col-account-amount">₹{{ account.total_balance|float }}</div>
                <div style="text-align: right">₹{{ account.total_billable_charge_items |float }}</div>
            </div>
        </div>




        <div class="note-text""> Note:Content of the {{report_title | capitalize}} will not be changed for any reason once the patient is discharged from the hospital. Please bring this report when you come for checkup.This {{report_title | capitalize}} is not a legal document or certificate. </div>
         <div class=" footer"> This is a computer-generated {{report_title | capitalize}}. </div>
    </div>
</body>

</html>