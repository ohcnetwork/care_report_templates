{% set report_title = "Medication Certificate" %}
{% set logo_img = "enter_logo_image_url" %}
{% set medication_certificate_questionnaire = "enter_specified_questionnaire_slug"%}

<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <style>
        @page {
            size: A4;
            margin: 140px 40px 80px 40px;
        }


        body {
            line-spacing: 1.6;
            font-family: "Times New Roman", Times, serif;
            margin: 0;
            padding: 0;
            max-width: 100%;
            font-size: 14px;
        }

        h1,
        h2,
        h3 {
            color: #2E8B57;
        }

        h1 {
            text-align: center;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        h2,
        h3 {
            border-bottom: 1px solid #333;
        }

        table {
            width: 100%;
            margin: 10px 0 5px 0;
            border: none;
            line-height: 1.2;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 4px 8px;
            text-align: left;
            font-size: 10px;
        }

        th {
            background-color: #F2F2F2;

        }

        .sub-table th {
            background-color: #FAFAFA;
            font-size: 10px;
        }

        .sub-table th,
        .sub-table td {

            margin-top: 30px;
        }

        .sub-table {
            white-space: pre-line;
            overflow-wrap: break-word;
        }

        .no-border,
        .no-border th,
        .no-border td {
            border: none !important;
            padding: 3px;
        }

        .no-border th {
            background-color: transparent !important;
        }


        .footer {
            margin-top: 8px;
            padding-top: 0;
            border-top: 1px solid #333;
            font-size: 8px;
            color: #666;
            text-align: center;
        }

        .separator {
            border-top: 1px solid #333;
            margin: 20px 0;
        }

        .header {
            position: fixed;
            top: -150px;
            left: 0;
            right: 0;

            height: 120px;
            padding: 10px;

            display: flex;
            justify-content: space-between;
            align-items: center;

            background: white;


            z-index: 2;
        }


        .header-logo {
            height: 50px;
            width: auto;
        }

        .header-title {
            flex-grow: 1;
            text-align: center;
        }

        .header-title h1 {
            margin: 0;
            border: none;
            padding: 0;
            font-size: 24px;
            color: #2E8B57;
        }

        .header-placeholder {
            width: 100%;
        }

        .content {
            position: relative;
            z-index: 5;
            margin-top: -40px;

            @media print {
                .header {
                    display: flex !important;
                }
            }
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="header-title">
            <h1 style="text-align: left;">{{ encounter.facility.name }}</h1>
            <div style="text-align: left; font-size:10px;">{{ encounter.facility.address }}<p>{{
                    encounter.facility.phone_number }}</p>
            </div>
        </div>
        <img alt="Logo" src={{logo_img}}
            style="height: 100px; width: auto;">
    </div>

    <div class="content">
        <h3 style="text-align: center;">{{report_title}}</h3>
        {% set ns = namespace(
        from_date=None,
        diagnosis=None,
        reg_no=None,
        days=None,
        user=None
        ) %}

        {% set qr = encounter.questionnaire_responses.filter(slug=medication_certificate_questionnaire)| list %}

        {% if qr %}
        {% set qr = qr | first %}
        {% for resp in qr.responses %}
        {% set ns.user = qr.updated_by.full_name %}
        {% set label = resp.question.get('text', resp.question) %}
        {% set values = resp.answer.get('values', [resp.answer]) %}

        {% for v in values %}

        {% if label == "From Date" %}
        {% set ns.from_date = v.value %}
        {% elif label == "Diagnosis" %}
        {% set ns.diagnosis = v.value %}
        {% elif label == "Registration No" %}
        {% set ns.reg_no = v.value %}
        {% elif label == "Number Of Days" %}
        {% set ns.days = v.value %}
        {% endif %}

        {% endfor %}

        {% endfor %}
        {% endif %}

        <div style="margin-top:100px; font-size:14px; line-height:1.6;width:70%;">
            <div style="display:flex;justify-content:space-between;margin:20px 0px;">
                <div>Date: {{ current_date() }}</div>
                <div>Signature of applicant</div>
            </div>
            <br><br>
            Mr./Ms. <b>{{ encounter.patient.name }}</b>, {{ encounter.patient.address }}
            whose signature is given above is suffering from
            <b>{{ ns.diagnosis }}</b> and I consider that a period of absence
            from duty of <b>{{ ns.days }} days</b> with effect from
            <b>{{ ns.from_date | date }}</b> is absolutely necessary for the
            restoration of his/her health.

        </div>
        <div style="margin-top: 60px; text-align: left;font-size:12px">

            <div style="font-weight: bold;">
                {{ns.user }}
            </div>
            <div>
                Reg No : {{ ns.reg_no }}
            </div>
        </div>

</body>

</html>